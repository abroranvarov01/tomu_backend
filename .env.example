PORT=8000
JWT_SECRET_KEY=ok
JWT_EXPIRED_IN=1d
REDIS_PORT=6379
REDIS_HOST=redis
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE=lms
DATABASE_PASSWORD=
DATABASE_USER=
VIMEO_CLIENT_ID=your_client_id
VIMEO_CLIENT_SECRET=your_client_secret
VIMEO_ACCESS_TOKEN=your_access_token

# AI Configuration
OPENAI_API_KEY=your_openai_api_key
GPT_MODEL=gpt-5
WHISPER_MODEL=whisper-1
TTS_MODEL=tts-1-hd
TTS_VOICE=shimmer
TTS_SPEED=0.9
MAX_TOKENS=200
TEMPERATURE=0.3
CONTEXT_MAX_LENGTH=8000
STRICT_NO_ECHO=1

# RAG Configuration
USE_RAG=1
USE_RAG_STRICT=0
RAG_TOP_K=12
EMBED_MODEL=text-embedding-3-small
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=lessons
CHROMA_API_VERSION=1

# OAuth Configuration
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=./secrets/apple-private-key.p8
APPLE_CALLBACK_URL=http://localhost:8000/api/auth/apple/callback

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_TEACHERS_GROUP_ID=-1001234567890
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/telegram/webhook
TELEGRAM_USE_WEBHOOK=false
