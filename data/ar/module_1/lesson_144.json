  "dialogue": [
    {
      "speaker": "المُعَلِّمُ",
      "text": "الثُّومُ خُضَارٌ حَارٌّ جِدًّا.",
      "translationUz": "Sarimsoq juda achchiq sabzavotdir.",
      "next": "أَكْثَرُ النَّاسِ لَا يُحِبُّونَ رَائِحَتَهُ."
    },
    {
      "speaker": "الطَّالِبُ",
      "text": "لَكِنَّهُ مُفِيدٌ جِدًّا لِصِحَّةِ الإِنْسَانِ.",
      "translationUz": "Ammo u inson salomatligi uchun juda foydalidir.",
      "next": "هَلْ تَأْكُلُ الثُّومَ؟"
    },
    {
      "speaker": "الطَّالِبُ",
      "text": "نَعَمْ، أَكُلُهُ أَبْيَضًا وَ أَخْضَرًا.",
      "translationUz": "Ha, men uni oq va yashil holda yeyman.",
      "next": "أَيُّ طَبِيبٍ يَنصَحُ بِهِ؟"
    },
    {
      "speaker": "المُعَلِّمُ",
      "text": "الطَّبِيبُ يُوصِي بِالثُّومِ لِصِحَّةِ القَلْبِ.",
      "translationUz": "Shifokor sarimsoqni yurak sog‘ligi uchun tavsiya qiladi.",
      "next": null
    }
  ]
