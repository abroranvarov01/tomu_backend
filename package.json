    "js-tiktoken": "^1.0.21",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "music-metadata": "^11.11.0",
    "nest-commander": "^3.20.1",
    "nestjs-ioredis": "^0.1.8",
    "nestjs-redis": "^1.3.3",
    "node-schedule": "^2.1.1",
    "node-telegram-bot-api": "^0.66.0",
    "otp-generator": "^4.0.1",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.2",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.13.0",
